rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isAdmin() {
      return isSignedIn() && userDoc().data.role == 'admin';
    }

    function isTestBot(userId) {
      return userId.matches('test-bot-.*');
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == userId ||
        (isAdmin() && isTestBot(userId))
      );
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          request.auth.uid == userId &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'email', 'createdAt'])
        )
      );
      allow delete: if isAdmin();
    }

    match /weaknesses/{weaknessId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /lobbies/{lobbyId} {
      allow read: if isSignedIn();
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        (
          resource.data.status == 'open' &&
          request.resource.data.status in ['open', 'confirming'] &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slots', 'acceptances', 'status', 'acceptDeadline', 'phaseTimerEndsAt', 'updatedAt'])
        ) ||
        (
          resource.data.status == 'confirming' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['acceptances', 'status', 'updatedAt'])
        ) ||
        (
          resource.data.status == 'voting_lineup' &&
          !resource.data.votes.locked &&
          request.auth.uid in resource.data.slots &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'status', 'phaseTimerEndsAt', 'updatedAt'])
        ) ||
        (
          resource.data.status == 'voting_proposals' &&
          !resource.data.votes.locked &&
          request.auth.uid in resource.data.slots &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'status', 'phaseTimerEndsAt', 'updatedAt'])
        ) ||
        (
          resource.data.status == 'weakness_pick' &&
          request.auth.uid == resource.data.weaknesses.selectorUid &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['weaknesses', 'status', 'updatedAt'])
        ) ||
        (
          resource.data.status == 'weakness_reveal' &&
          request.auth.uid in resource.data.slots &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['weaknesses', 'updatedAt', 'status']) &&
          request.resource.data.status in ['weakness_reveal', 'weakness_pick']
        )
      );
      allow delete: if isAdmin();
    }
  }
}
